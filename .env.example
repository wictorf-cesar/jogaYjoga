# RAG embedding model cache (optional — defaults to ./.cache/sentence-transformers)
# Set on PaaS like Render so the ~90MB model is downloaded once and reused
# across cold starts (the repo dir persists between deploys).
# SENTENCE_TRANSFORMERS_HOME=/opt/render/project/.cache/sentence-transformers
# HF_HOME=/opt/render/project/.cache/huggingface
